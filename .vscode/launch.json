{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug MPS2 AN521 BL2 in QEMU",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "servertype": "external",
            "gdbTarget": "localhost:3333",
            "gdbPath": "/opt/arm-gnu-toolchain/arm-gnu-toolchain-14.2.rel1-x86_64-arm-none-eabi/bin/arm-none-eabi-gdb",
            "executable": "${workspaceFolder}/build/api_ns/bin/bl2.axf",
            "loadFiles": [],
            "postLaunchCommands": [
                "add-symbol-file ${workspaceFolder}/build/api_ns/bin/tfm_s.axf",
                "add-symbol-file ${workspaceFolder}/build_test/bin/tfm_ns.axf"
            ],
            "device": "Cortex-M33",
            "runToEntryPoint": "Reset_Handler",
            "overrideLaunchCommands": [],
            "overrideResetCommands": [],
            "preLaunchTask": "Start MPS2 AN521 QEMU GDB Server",
            "showDevDebugOutput": "none"
        }
    ]
}
