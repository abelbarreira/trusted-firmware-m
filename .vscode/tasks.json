{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup Python",
            "type": "process",
            "command": ".scripts/setup_python.sh",
            "options": {
                "statusbar": {
                    "hide": false
                }
            }
        },
        {
            "label": "Build MPS2 AN521 SPE APP",
            "type": "process",
            "command": ".scripts/build_mps2_an521_spe_app.sh",
            "options": {
                "statusbar": {
                    "hide": false
                }
            }
        },
        {
            "label": "Build MPS2 AN521 BLX BL2 SPE APP",
            "type": "process",
            "command": ".scripts/build_mps2_an521_blx_bl2_spe_app.sh",
            "options": {
                "statusbar": {
                    "hide": false
                }
            }
        },
        {
            "label": "Start MPS2 AN521 QEMU GDB Server",
            "type": "shell",
            "command": "qemu-system-arm",
            "args": [
                "-machine", "mps2-an521",
                "-cpu", "cortex-m33",
                "-nographic",
                "-monitor", "none",
                "-serial", "stdio",
                "-S",
                "-gdb", "tcp::3333",
                "-kernel", "build/api_ns/bin/bl2.axf",
                "-device", "loader,file=build_test/tfm_s_ns_signed.bin,addr=0x10080000"
            ],
            "isBackground": true,
            "problemMatcher": {
                "owner": "qemu",
                "pattern": {
                    "regexp": "^(.*)$",
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "^.*$",
                    "endsPattern": "Listening for gdb connection on device 'tcp::3333'"
                }
            },
            "options": {
                "statusbar": {
                    "hide": false
                }
            }
        }
    ]
}
